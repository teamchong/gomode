{
  "name": "gomode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:zig": "tsx scripts/build-zig-abi.ts",
    "build:go": "tsx scripts/build-tinygo.ts",
    "build": "npm run build:zig && npm run build:go",
    "dev": "cd worker && npx wrangler dev",
